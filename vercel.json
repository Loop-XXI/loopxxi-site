{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/.well-known/lnurlp/:user/callback",
      "destination": "https://loopxxi-hub-production.up.railway.app/api/lnurlp/:user/callback"
    },
    {
      "source": "/.well-known/lnurlp/:user",
      "destination": "https://loopxxi-hub-production.up.railway.app/api/lnurlp/:user"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/nostr.json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Content-Type", "value": "application/json" }
      ]
    },
    {
      "source": "/.well-known/lnurlp/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
